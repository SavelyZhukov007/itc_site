# Базовый адрес сайта после публикации
VITE_SITE_URL=https://example.com

# Google Analytics 4
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Yandex Metrika
VITE_YANDEX_METRIKA_ID=00000000

# Необязательно: внешний адрес backend API.
# Если переменная не указана, фронтенд использует /api и локальный proxy Vite.
VITE_API_BASE_URL=

# Backend
BACKEND_PORT=8787
FORM_STORAGE_FILE=applications.json

# Telegram bot
TG_BOT_TOKEN=
TG_CHAT_ID=
